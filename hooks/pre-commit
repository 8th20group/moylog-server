#!/bin/bash
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep "\.java$")

if [ -n "$STAGED_FILES" ]; then
    if grep -q "System.out.println" $STAGED_FILES; then
        echo "❌ System.out.println이 발견되었습니다! 로깅 라이브러리를 사용하세요."
        exit 1
    fi
fi

echo "✅ Complete pre-commit verification"
exit 0